{
  "name": "propkub",
  "description": "Open-source monorepo for PropKub.com - Thailand's property marketplace",
  "author": "Goff Phatt",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api"
  },
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
